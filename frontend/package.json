{
  "name": "c-turismo-gestao-de-clientes",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:frontend": "vite",
    "backend": "python -m uvicorn backend_cturismo.main:app --host 0.0.0.0 --port 8000",
