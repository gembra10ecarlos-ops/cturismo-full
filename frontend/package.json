    "react-dom": "^19.2.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "kill-port": "^2.0.1",
    "concurrently": "^9.0.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
